<% layout('/layouts/boilerplate') %>

<div class="container mt-5">
    <h2>My Bookings</h2>

    <% if (bookings.length === 0) { %>
        <p class="text-muted">You haven't booked any listing yet.</p>
        <a href="/listings" class="btn btn-primary">Browse Listings</a>
    <% } else { %>
        <div class="row">
            <% bookings.forEach(booking => { %>
                <div class="col-md-4 mb-4">
                    <div class="card">
                        <img src="<%= booking.listing.image.url %>" class="card-img-top" alt="<%= booking.listing.title %>">
                        <div class="card-body">
                            <h5 class="card-title"><%= booking.listing.title %></h5>
                            
                            <p class="card-text">
                                <small>
                                    <strong>Check-in:</strong> <%= new Date(booking.checkInDate).toLocaleDateString() %><br>
                                    <strong>Check-out:</strong> <%= new Date(booking.checkOutDate).toLocaleDateString() %><br>
                                    <strong>Total Price:</strong> ₹<%= booking.totalPrice %><br>
                                    <strong>Status:</strong> 
                                    <% if (booking.paymentStatus === 'completed') { %>
                                        <span class="badge bg-success">Confirmed</span>
                                    <% } else { %>
                                        <span class="badge bg-warning">Pending</span>
                                    <% } %>
                                </small>
                            </p>

                            <a href="/bookings/<%= booking._id %>" class="btn btn-info btn-sm">View Details</a>
                            
                            <% if (booking.paymentStatus === 'pending') { %>
                                <form action="/bookings/<%= booking._id %>?_method=DELETE" method="POST" style="display: inline;">
                                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Cancel this booking?')">Cancel</button>
                                </form>
                            <% } %>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>
    <% } %>
</div>
