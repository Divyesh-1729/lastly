<style>
  .navbar {
    padding: 0.5rem 0;
  }
  .navbar-brand {
    margin-right: 1rem;
    font-size: 1.3rem;
  }
  .navbar-nav {
    gap: 0.5rem;
  }
  .search-btn{
    background-color: #fe424d;
    color: white;
    border-radius: 25px;
    padding: 0.4rem 1rem;
    margin-left: 0.3rem;
    font-size: 0.9rem;
    white-space: nowrap;
  }
  .search-btn:hover{
    background-color: #e63946;
    color: white;
    transition: background-color 0.5s ease;
  }
  .search-btn i {
    display: none;
  }
  .search-input{
    border-radius: 25px;
    padding: 0.4rem 1rem;
    font-size: 0.9rem;
    max-width: 200px;
  }
  .nav-item {
    list-style: none;
    padding: 0;
  }
  .nav-item .nav-link {
    padding: 0.3rem 0.5rem;
  }
  .me-3 {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-left: 0.5rem;
  }
  .d-flex {
    gap: 0;
  }
  .brand-name {
    color: #fe424d;
  }
</style>




<nav class="navbar navbar-expand-lg bg-body-tertiary border-bottom sticky-top">
  <div class="container">
    <a class="navbar-brand brand-name" href="/listings"><i class="fa-regular fa-compass"></i>  Wanderlust</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarTogglerDemo02" aria-controls="navbarTogglerDemo02" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarTogglerDemo02">
      <div class="navbar-nav me-auto mb-2 mb-lg-0">
        
          <a class="nav-link" href="/listings">Explore</a>
         
      </div>
      <div class="navbar-nav ms-auto mb-2 mb-lg-0">
      <form class="d-flex" role="search" action="/listings/search" method="GET">
        <input class="form-control search-input" type="search" name="q" placeholder="Search Destinations" aria-label="Search"/>
        <button class="btn search-btn" type="submit">Search</button>
      </form>
      </div>

      
      <div class="me-3">
        <% if(typeof currentUser !== 'undefined' && currentUser) { %>
          <li class="nav-item">
            <a class="nav-link" href="/listings/new">Add new Listing</a>
          </li>
        <% } %>
        <% if(typeof currentUser === 'undefined' || !currentUser) { %>
          <a class="btn btn-outline-primary btn-sm" href="/signup" role="button"><b>Sign Up</b></a>
          <a class="btn btn-outline-success btn-sm" href="/login" role="button"><b>Log In</b></a>
        <% } else { %>
          <span class="me-2">Hello, <strong><%= currentUser.username %></strong></span>
          <a class="btn btn-outline-danger btn-sm" href="/logout" role="button">Log Out</a>
        <% } %>

      </div>
      
    </div>
  </div>
</nav>