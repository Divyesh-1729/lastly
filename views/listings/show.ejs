<% layout('/layouts/boilerplate') %>
<div class="row mt-3">
    <div class="col-8 offset-2">
        <h3><%= listing.title %></h3>

        <div class="card show-card">
            <img class="card-img-top show-img" src="<%= listing.image.url %>" alt="Listing image">
            <div class="card-body">
                <p class="card-text">
                    <p><i>Listed by: <b><%= listing.owner ? listing.owner.username : "Unknown" %></b></i><br/></p>
                    <br/>
                    <b><%= listing.title %></b><br/>
                    <%= listing.description %> <br/>
                    &#x20B9;<%= listing.price.toLocaleString("en-IN") %> /night <br/>
                    <%= listing.location %> <br/>
                    <%= listing.country %> <br/>
                </p>
            </div>
        </div>

    <br>
        
        <div class="d-flex gap-3 mt-0" style="max-width: 600px;">
            <% if(currentUser && listing.owner && listing.owner._id.equals(currentUser._id)) { %>
                <!-- EDIT BUTTON -->
                <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark btn-sm w-100 py-1">
                    Edit
                </a>

                <!-- DELETE BUTTON -->
                <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
                    <button type="submit" class="btn btn-danger btn-sm w-100 py-1">
                        Delete
                    </button>
                </form>
            <% } %>
        </div>

        

        <% if(currentUser){ %>
            <hr/>
            <h4>Leave a review</h4>
            <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
                <!-- <div class="mb-3 mt-3 form-range">
                    <label for="rating" class="form-label">Rating:</label>
                    <input type="range" min="1" max="5" id="rating" name="review[rating]" required>
                    <div class="invalid-feedback">Please provide a rating.</div>          
                </div> -->
                <div class="mb-3 mt-3 form-range">
                  <label for="rating" class="form-label">Rating:</label>
                <fieldset class="starability-slot">
                  
  <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
  <input type="radio" id="first-rate1" name="review[rating]" value="1" />
  <label for="first-rate1" title="Terrible">1 star</label>
  <input type="radio" id="first-rate2" name="review[rating]" value="2" />
  <label for="first-rate2" title="Not good">2 stars</label>
  <input type="radio" id="first-rate3" name="review[rating]" value="3" />
  <label for="first-rate3" title="Average">3 stars</label>
  <input type="radio" id="first-rate4" name="review[rating]" value="4" />
  <label for="first-rate4" title="Very good">4 stars</label>
  <input type="radio" id="first-rate5" name="review[rating]" value="5" />
  <label for="first-rate5" title="Amazing">5 stars</label>
</fieldset>
</div>
<br>
                <div class="mb-3 mt-3">
                    <label for="comment" class="form-label">Comment:</label>
                    <textarea id="comment" name="review[comment]" rows="4" cols="50" class="form-control" required></textarea>
                    <div class="invalid-feedback">Please provide a comment.</div>
                </div>
                <br>
                <button type="submit" class="btn btn-primary mt-2">Submit Review</button>
            </form>
            <hr style="border: 3px solid #222222; margin-top: 3rem; margin-bottom: 3rem;"/>
        <% } %>
        
        <% if(listing.reviews.length > 0){ %>
            
        <div class="row">
            <h4>All Reviews</h4>
            <% for(review of listing.reviews){ %>
                <div class="card col-6 mb-3">
                    <div class="card-body">
                        <h5 class="card-title">Review by <b><%= review.author.username %></b></h5>
                        <p class="starability-result card-text" data-rating="<%= review.rating %>"></p>
                        <p class="card-text"><%= review.comment %></p>
                        <form class="mb-3" method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                            <button class="btn btn-danger btn-sm mb-3">Delete Review</button>
                        </form>
                    </div>
                </div>
            <% } %>
        </div>
        <% } %>
        <hr style="border: 3px solid #222222; margin-top: 3rem; margin-bottom: 3rem;"/>
        </div>
        
        <div class="col-6 offset-2 mb-3">
            <h3>Where you'll be</h3>
            <div
                id="map"
                style="height: 400px; width:100% "
                data-title="<%= listing.title %>"
                data-location-text="<%= [listing.location, listing.country].filter(Boolean).join(', ') %>"
                data-lat="<%= (listing.geometry && listing.geometry.coordinates) ? listing.geometry.coordinates[1] : '' %>"
                data-lng="<%= (listing.geometry && listing.geometry.coordinates) ? listing.geometry.coordinates[0] : '' %>"
            ></div>
        </div>
        
        <script src="/js/map.js"></script>
        <script src="https://maps.googleapis.com/maps/api/js?key=<%= process.env.MAP_API_KEY %>&callback=initMap" async defer></script>
    </div>
</div>


