<% layout("/layouts/boilerplate") %>
<body>
    <style>
        #filters {
            display: flex;
            gap: 10px;
            margin-top: 1rem;
            margin-bottom: 0.5rem;
            padding: 0.5rem 0.5rem;
            align-items: center;
            justify-content: flex-start;
        }
        .filter{
            text-align: center;
            padding: 0.25rem 0;
            opacity:0.7;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            flex: 1;
            min-width: 60px;
            transition: opacity 0.3s ease;
        }
        .filter:hover{
            opacity:1;
            cursor: pointer;
        }
        .filter i{
            font-size: 1.3rem;
            margin-bottom: 0.2rem;
        }
        .filter p{
            font-size: 0.8rem;
            margin: 0;
            font-weight: 500;
            word-wrap: break-word;
        }
        .tax-info{
            display: none;
            font-size: 0.8rem;
            color: grey;
        }
        .tax-toggle{
            border: 1px solid black;
            border-radius: 1rem;
            height: 3rem;
            padding: 0.5rem 1rem;
            display:flex;
            align-items: center;
            margin-left: auto;
            flex-shrink: 0;
        }
        </style>
   <%# Displaying flash success messages. Instead of here we will flash them in boilerplate.ejs so that they appear on all pages. %>
