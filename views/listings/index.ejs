        <div class="tax-toggle">
             <div class="form-check-reverse form-switch">
             <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
             <label class="form-check-label" for="switchCheckDefault">After the taxes</label>
             </div>
        </div>
    </div>
    <div class="row row-cols-lg-3 row-cols-md-3 row-cols-sm-2 row-cols-1 g-4 mt-3">
        <% for(let listing of allListings){%>
            <a href="/listings/<%= listing._id %>" class="listing-link">

    <div class="card column" style="width: 20rem;">
  <img class="card-img-top" src="<%= listing.image.url %>" alt="Listing image" style="height: 20rem;">
  <div class="card-img-overlay"></div>
  <div class="card-body">
    <p class="card-text">
       <b> <%= listing.title %> </b><br/>
        &#x20B9;<%= listing.price.toLocaleString("en-IN") %> /night <br/>
        <i class="tax-info"> &nbsp; &nbsp; +18% GST </i>

    </p>
  </div>
</div>
</a>
<% } %>
    </div>
    
