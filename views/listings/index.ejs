</body>



<script>
    let taxSwitch = document.getElementById("switchCheckDefault");
    taxSwitch.addEventListener("change", () =>
    {
        let taxInfo = document.getElementsByClassName("tax-info");
        const show = taxSwitch.checked;
        for (let info of taxInfo) {
            info.style.display = show ? "block" : "none";
        }
    });

    // Handle category filter clicks
    const filterButtons = document.querySelectorAll('.filter');
    filterButtons.forEach(button => {
        button.addEventListener('click', () => {
            const category = button.getAttribute('data-category');
            window.location.href = `/listings?category=${category}`;
        });
    });

    // Highlight the selected category filter
    const selectedCategory = '<%= selectedCategory %>';
    if(selectedCategory && selectedCategory !== 'null') {
        filterButtons.forEach(button => {
            if(button.getAttribute('data-category') === selectedCategory) {
                button.style.opacity = '1';
                button.style.fontWeight = 'bold';
            }
        });
    }
</script>




